{
  "buildCommand": "bun run build",
  "outputDirectory": "dist/client",
  "devCommand": "bun run dev",
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x"
    },
    "api/[...].ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/[...]?path=$1"
    }
  ]
}
