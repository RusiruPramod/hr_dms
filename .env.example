# Example .env.example — copy to `.env` and fill values (DO NOT commit secrets)
VITE_API_KEY=your_api_key_here
VITE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_PROJECT_ID=your-project-id
VITE_STORAGE_BUCKET=your-project.appspot.com
VITE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_APP_ID=your_app_id

# Server-side (used by Firebase Admin)
# Provide the service account JSON as a base64-encoded string
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Database and other runtime secrets
DATABASE_URL=postgres://user:pass@host:5432/hr_dms
JWT_SECRET=replace_with_strong_secret
